<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="shortcut icon" href="@Url.Content("~/favicon.ico")" type="image/x-icon" />
    <title>@ViewBag.Title - Pura Vida Buses</title>

    <link href="~/Template/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/Template/css/fullcalendar.css" rel="stylesheet" />
    <link href="~/Template/css/lineicons.css" rel="stylesheet" />
    <link href="~/Template/css/main.css" rel="stylesheet" />
    <link href="~/Template/css/materialdesignicons.min.css" rel="stylesheet" />
    <link href="~/Template/css/styles.css" rel="stylesheet" />
</head>
<body>
    <div id="preloader">
        <div class="spinner"></div>
    </div>

    <aside class="sidebar-nav-wrapper">
        <div class="navbar-logo">
            <a href="@Url.Action("Inicio", "Home")" style="font-size: 24px; font-weight: bold; color: #2f54eb; text-decoration: none;">
                Pura Vida Buses
            </a>
        </div>

        <nav class="sidebar-nav">
            <ul>
                <li class="nav-item nav-item-has-children">
                    <a href="#0"
                       class="collapsed"
                       data-bs-toggle="collapse"
                       data-bs-target="#ddmenu_1"
                       aria-controls="ddmenu_1"
                       aria-expanded="false"
                       aria-label="Toggle navigation">
                        <span class="icon">
                            <i class="lni lni-dashboard"></i>
                        </span>
                        <span class="text">Dashboard</span>
                    </a>
                    <ul id="ddmenu_1" class="collapse dropdown-nav">
                        <li>
                            <a href="@Url.Action("Index", "Home")">Página principal</a>
                        </li>
                    </ul>
                </li>

                <li class="nav-item">
                    <a href="@Url.Action("Inicio", "Home")">
                        <span class="icon"><i class="lni lni-home"></i></span>
                        <span class="text">Inicio</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a href="@Url.Action("Login", "Home")">
                        <span class="icon"><i class="lni lni-user"></i></span>
                        <span class="text">Registrate</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a href="@Url.Action("Informacion", "Home")">
                        <span class="icon"><i class="lni lni-map"></i></span>
                        <span class="text">Rutas</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a href="@Url.Action("Horario", "Home")">
                        <span class="icon"><i class="lni lni-alarm-clock"></i></span>
                        <span class="text">Horarios</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a href="@Url.Action("About", "Home")">
                        <span class="icon"><i class="lni lni-information"></i></span>
                        <span class="text">Acerca de</span>
                    </a>
                </li>
            </ul>
        </nav>
    </aside>

    <div class="overlay"></div>

    <main class="main-wrapper">
        <header class="header">
            <div class="container-fluid">
                <div class="row">
                    <div class="col-lg-5 col-md-5 col-6">
                        <div class="header-left d-flex align-items-center">
                            <div class="menu-toggle-btn mr-15">
                                <button id="menu-toggle" class="main-btn primary-btn btn-hover">
                                    <i class="lni lni-chevron-left me-2"></i> Menu
                                </button>
                            </div>

                            <div class="header-search d-none d-md-flex">
                                <form action="#">
                                    <input type="text" placeholder="Buscar..." />
                                    <button type="submit"><i class="lni lni-search-alt"></i></button>
                                </form>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-7 col-md-7 col-6">
                        <div class="header-right">

                            <!-- profile start -->
                            <div class="profile-box ml-15">
                                <button class="dropdown-toggle bg-transparent border-0" type="button" id="profile"
                                        data-bs-toggle="dropdown" aria-expanded="false">
                                    <div class="profile-info">
                                        <div class="info">
                                            <div>
                                                <h6 class="fw-500">
                                                    @(Session["UsuarioNombre"] != null ? Session["UsuarioNombre"].ToString() : "Invitado")
                                                </h6>
                                                <p>
                                                    @(Session["UsuarioEmail"] != null ? Session["UsuarioEmail"].ToString() : "Pura Vida Buses")
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                </button>

                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="profile">
                                    <li>
                                        <div class="author-info flex items-center !p-1">
                                            <div class="content">
                                                <h4 class="text-sm">
                                                    @(Session["UsuarioNombre"] != null ? Session["UsuarioNombre"].ToString() : "Invitado")
                                                </h4>
                                                <a class="text-black/40 text-xs" href="#0">
                                                    @(Session["UsuarioEmail"] != null ? Session["UsuarioEmail"].ToString() : "admin@puravidabuses.cr")
                                                </a>
                                            </div>
                                        </div>
                                    </li>

                                    <li class="divider"></li>

                                    <li>
                                        <a href="@Url.Action("Inicio", "Home")">
                                            <i class="lni lni-home"></i> Inicio
                                        </a>
                                    </li>

                                    <li>
                                        <a href="@Url.Action("Informacion", "Home")">
                                            <i class="lni lni-information"></i> Información
                                        </a>
                                    </li>

                                    <li>
                                        <a href="@Url.Action("Horario", "Home")">
                                            <i class="lni lni-alarm"></i> Horarios
                                        </a>
                                    </li>

                                    <li class="divider"></li>

                                    <li>
                                        <a href="@Url.Action("CerrarSesion", "Home")">
                                            <i class="lni lni-exit"></i> Cerrar sesión
                                        </a>
                                    </li>
                                </ul>
                            </div>
                            <!-- profile end -->

                        </div>
                    </div>
                </div>
            </div>
        </header>

        <section class="section">
            <div class="container-fluid">
                @RenderBody()
            </div>
        </section>

        <footer class="footer">
            <div class="container-fluid">
                <div class="row">
                    <div class="col-md-6 order-last order-md-first">
                        <div class="copyright text-center text-md-start">
                            <p class="text-sm">
                                Proyecto académico - Pura Vida Buses
                            </p>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="terms d-flex justify-content-center justify-content-md-end">
                            <a href="#0" class="text-sm">Términos</a>
                            <a href="#0" class="text-sm ml-15">Privacidad</a>
                        </div>
                    </div>
                </div>
            </div>
        </footer>
    </main>

    <script src="~/Template/js/bootstrap.bundle.min.js"></script>
    <script src="~/Template/js/Chart.min.js"></script>
    <script src="~/Template/js/dynamic-pie-chart.js"></script>
    <script src="~/Template/js/moment.min.js"></script>
    <script src="~/Template/js/fullcalendar.js"></script>
    <script src="~/Template/js/jvectormap.min.js"></script>
    <script src="~/Template/js/world-merc.js"></script>
    <script src="~/Template/js/polyfill.js"></script>
    <script src="~/Template/js/main.js"></script>
</body>
</html>