@{
    ViewBag.Title = "Inicio de sesión";
}

<div class="row justify-content-center">
    <div class="col-lg-6 col-md-8 col-sm-12">
        <div class="card-style mb-30">
            <h4 class="mb-25 text-center">Acceso</h4>

            @if (ViewBag.Mensaje != null)
            {
                <div class="alert alert-info text-center">
                    @ViewBag.Mensaje
                </div>
            }

            @using (Html.BeginForm("Inicio", "Home", FormMethod.Post))
            {
                <div class="input-style-1">
                    <label>Correo Electrónico</label>
                    <input type="email" name="email" placeholder="ejemplo@correo.com" required />
                </div>

                <div class="input-style-1">
                    <label>Contraseña</label>
                    <input type="password" name="password" placeholder="Ingrese su contraseña" required />
                </div>

                <div class="text-center mt-20">
                    <button type="submit" class="main-btn primary-btn btn-hover w-100">
                        Iniciar sesión
                    </button>
                </div>

                <div class="text-center mt-15">
                    <p class="text-sm">
                        ¿No tienes cuenta?
                        <a href="@Url.Action("Login", "Home")">Regístrate aquí</a>
                    </p>
                </div>
            }
        </div>
    </div>
</div>