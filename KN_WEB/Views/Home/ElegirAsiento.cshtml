@using System.Data
@{
    ViewBag.Title = "Elegir Asiento";
    var ocupados = ViewBag.AsientosOcupados as DataTable;
    var listaOcupados = new List<string>();

    if (ocupados != null)
    {
        foreach (DataRow fila in ocupados.Rows)
        {
            listaOcupados.Add(fila["numero_asiento"].ToString());
        }
    }
}

<style>
    .bus-container {
        max-width: 900px;
        margin: auto;
        text-align: center;
    }

    .bus-front {
        width: 220px;
        margin: 0 auto 25px auto;
        padding: 12px;
        border-radius: 20px;
        background: #e9ecef;
        font-weight: bold;
    }

    .seat-map {
        display: grid;
        grid-template-columns: repeat(4, 70px) 40px repeat(4, 70px);
        gap: 12px;
        justify-content: center;
        margin-bottom: 30px;
    }

    .aisle {
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        color: #777;
    }

    .seat {
        width: 70px;
        height: 50px;
        border: 2px solid #0d6efd;
        border-radius: 10px;
        background: white;
        color: #0d6efd;
        cursor: pointer;
        font-weight: bold;
        transition: 0.2s;
    }

        .seat:hover {
            transform: scale(1.05);
        }

        .seat.selected {
            background: #198754;
            border-color: #198754;
            color: white;
        }

        .seat.occupied {
            background: #6c757d;
            border-color: #6c757d;
            color: white;
            cursor: not-allowed;
        }

    .legend {
        display: flex;
        justify-content: center;
        gap: 20px;
        margin: 25px 0;
        flex-wrap: wrap;
    }

    .legend-item {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .legend-box {
        width: 22px;
        height: 22px;
        border-radius: 6px;
        border: 2px solid #0d6efd;
        background: white;
    }

        .legend-box.selected {
            background: #198754;
            border-color: #198754;
        }

        .legend-box.occupied {
            background: #6c757d;
            border-color: #6c757d;
        }

    .seat-info {
        font-size: 18px;
        margin-bottom: 20px;
    }
</style>

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="card-style mb-30">
            <h2 class="text-center mb-4">Selecciona tu asiento</h2>

            <div class="bus-container">
                <div class="bus-front">Frente del bus</div>

                <div class="legend">
                    <div class="legend-item">
                        <div class="legend-box"></div>
                        <span>Disponible</span>
                    </div>
                    <div class="legend-item">
                        <div class="legend-box selected"></div>
                        <span>Seleccionado</span>
                    </div>
                    <div class="legend-item">
                        <div class="legend-box occupied"></div>
                        <span>Ocupado</span>
                    </div>
                </div>

                <div class="seat-info">
                    Asiento seleccionado: <strong id="textoAsiento">Ninguno</strong>
                </div>

                <div class="seat-map">
                    @{
                        int[] fila1 = { 1, 2, 3, 4, 5, 6, 7, 8 };
                        int[] fila2 = { 9, 10, 11, 12, 13, 14, 15, 16 };
                        int[] fila3 = { 17, 18, 19, 20, 21, 22, 23, 24 };
                        int[] fila4 = { 25, 26, 27, 28, 29, 30, 31, 32 };
                        int[] fila5 = { 33, 34, 35, 36, 37, 38, 39, 40 };
                        int[] fila6 = { 41, 42, 43, 44, 45, 46, 47, 48 };

                        var filas = new List<int[]> { fila1, fila2, fila3, fila4, fila5, fila6 };

                        foreach (var fila in filas)
                        {
                            for (int i = 0; i < fila.Length; i++)
                            {
                                if (i == 4)
                                {
                                    <div class="aisle">|</div>
                                }

                                string numero = fila[i].ToString();
                                bool ocupado = listaOcupados.Contains(numero);

                                <button type="button"
                                        class="seat @(ocupado ? "occupied" : "")"
                                        onclick="seleccionarAsiento('@numero', this)"
                                        @(ocupado ? "disabled" : "")>
                                    @numero
                                </button>
                            }
                        }
                    }
                </div>

                @using (Html.BeginForm("GuardarAsiento", "Home", FormMethod.Post))
                {
                    <input type="hidden" name="idReserva" value="@ViewBag.IdReserva" />
                    <input type="hidden" id="asientoSeleccionado" name="numeroAsiento" />

                    <div class="text-center mt-4">
                        <button type="submit" class="main-btn success-btn btn-hover" onclick="return validarAsiento();">
                            Confirmar asiento
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script>
    let botonSeleccionado = null;

    function seleccionarAsiento(numero, boton) {
        if (boton.classList.contains("occupied")) return;

        if (botonSeleccionado) {
            botonSeleccionado.classList.remove("selected");
        }

        boton.classList.add("selected");
        botonSeleccionado = boton;

        document.getElementById("asientoSeleccionado").value = numero;
        document.getElementById("textoAsiento").innerText = numero;
    }

    function validarAsiento() {
        const asiento = document.getElementById("asientoSeleccionado").value;
        if (!asiento) {
            alert("Debes seleccionar un asiento.");
            return false;
        }
        return true;
    }
</script>